{
  "name": "sharkreader",
  "version": "1.0.0",
  "description": "Lector de EPUB y PDF con IA, pestañas, Pomodoro y vocabulario",
  "main": "main.js",
  "author": "SharkReader",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "node scripts/dev.cjs",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --win nsis portable"
  },
  "build": {
    "appId": "com.sharkreader.app",
    "productName": "SharkReader",
    "copyright": "Copyright © 2025 SharkReader",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "dist-renderer/**",
      "icon_build.ico",
      "node_modules/**",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/.cache/**"
    ],
    "win": {
      "icon": "icon_build.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon_build.ico",
      "uninstallerIcon": "icon_build.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SharkReader",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "SharkReader-Portable-${version}.exe"
    }
  },
  "keywords": [],
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "epubjs": "^0.3.93",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
