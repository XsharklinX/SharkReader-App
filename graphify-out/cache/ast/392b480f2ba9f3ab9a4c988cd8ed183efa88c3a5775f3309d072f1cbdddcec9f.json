"source_file": "E:\\Programacion\\SharkReader-main\\src\\AnalyticsView.jsx", "source_location": "L277"}, {"caller_nid": "src_analyticsview_analyticsview", "callee": "(() => {\n                                const W = 600; const H = 100; const PAD = 10;\n                                const pts = weeklyData.map((d, i) => {\n                                    const x = PAD + (i / (weeklyData.length - 1)) * (W - PAD * 2);\n                                    const y = H - PAD - ((d.minutes / maxWeekly) * (H - PAD * 2));\n                                    return `${x},${y}`;\n                                });\n                                return (\n                                    <svg width=\"100%\" viewBox={`0 0 ${W} ${H + 16}`} preserveAspectRatio=\"none\">\n                                        <defs>\n                                            <linearGradient id=\"wkGrad\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n                                                <stop offset=\"0%\" stopColor=\"var(--highlight)\" stopOpacity=\"0.35\" />\n                                                <stop offset=\"100%\" stopColor=\"var(--highlight)\" stopOpacity=\"0.03\" />\n                                            </linearGradient>\n                                        </defs>\n                                        <path d={`M ${pts[0]} L ${pts.slice(1).join(' L ')} L ${pts[pts.length - 1].split(',')[0]},${H - PAD} L ${PAD},${H - PAD} Z`} fill=\"url(#wkGrad)\" />\n                                        <polyline points={pts.join(' ')} fill=\"none\" stroke=\"var(--highlight)\" strokeWidth=\"2\" strokeLinejoin=\"round\" strokeLinecap=\"round\" />\n                                        {weeklyData.map((d, i) => {\n                                            const x = PAD + (i / (weeklyData.length - 1)) * (W - PAD * 2);\n                                            const y = H - PAD - ((d.minutes / maxWeekly) * (H - PAD * 2));\n                                            return <circle key={i} cx={x} cy={y} r=\"3.5\" fill=\"var(--highlight)\" stroke=\"var(--surface-bg)\" strokeWidth=\"2\" />;\n                                        })}\n                                        <text x={PAD} y={H + 14} fontSize=\"9\" fill=\"currentColor\" opacity=\"0.3\">hace 12 sem</text>\n                                        <text x={W - PAD} y={H + 14} fontSize=\"9\" fill=\"currentColor\" opacity=\"0.3\" textAnchor=\"end\">esta sem</text>\n                                    </svg>\n                                );\n                            })", "is_member_call": false, "source_file": "E:\\Programacion\\SharkReader-main\\src\\AnalyticsView.jsx", "source_location": "L297"}, {"caller_nid": "src_analyticsview_analyticsview", "callee": "filter", "is_member_call": true, "source_file": "E:\\Programacion\\SharkReader-main\\src\\AnalyticsView.jsx", "source_location": "L329"}, {"caller_nid": "src_analyticsview_analyticsview", "callee": "map", "is_member_call": true, "source_file": "E:\\Programacion\\SharkReader-main\\src\\AnalyticsView.jsx", "source_location": "L344"}, {"caller_nid": "src_analyticsview_analyticsview", "callee": "slice", "is_member_call": true, "source_file": "E:\\Programacion\\SharkReader-main\\src\\AnalyticsView.jsx", "source_location": "L344"}, {"caller_nid": "src_analyticsview_analyticsview", "callee": "sort", "is_member_call": true, "source_file": "E:\\Programacion\\SharkReader-main\\src\\AnalyticsView.jsx", "source_location": "L344"}, {"caller_nid": "src_analyticsview_analyticsview", "callee": "filter", "is_member_call": true, "source_file": "E:\\Programacion\\SharkReader-main\\src\\AnalyticsView.jsx", "source_location": "L344"}, {"caller_nid": "src_analyticsview_analyticsview", "callee": "map", "is_member_call": true, "source_file": "E:\\Programacion\\SharkReader-main\\src\\AnalyticsView.jsx", "source_location": "L378"}]}